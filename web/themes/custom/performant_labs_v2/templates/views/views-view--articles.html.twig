{#
/**
 * @file
 * Articles view — fallback wrapper for all block displays of the articles view.
 *
 * Applies to articles:block_1, block_2, block_3 (and any other display that
 * does not have a more specific override). The page_1 display has its own
 * more specific template (views-view--articles--page-1.html.twig) which takes
 * precedence.
 *
 * Unlike the page_1 template, block displays are embedded inside Layout
 * Builder sections, so they do not need the <section class="articles-view">
 * full-page wrapper — they inherit the surrounding layout.
 */
#}
{%
  set classes = [
    'view',
    'view-' ~ id|clean_class,
    'view-id-' ~ id,
    'view-display-id-' ~ display_id,
    dom_id ? 'js-view-dom-id-' ~ dom_id,
  ]
%}
<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {% if title %}{{ title }}{% endif %}
  {{ title_suffix }}

  {% if exposed %}{{ exposed }}{% endif %}

  {% if rows %}
    <div class="view-content">{{ rows }}</div>
  {% elseif empty %}
    <div class="view-empty">{{ empty }}</div>
  {% endif %}

  {% if pager %}{{ pager }}{% endif %}
</div>
