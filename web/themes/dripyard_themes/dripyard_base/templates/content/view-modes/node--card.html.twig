{#
/**
 * @file
 * Implementation to display a node card.
 */
#}

{% set body_text %}
  {% if node.body.summary %}
    {{ node.body.summary }}
  {% else %}
    {{ content.body|add_suggestion('bare')|render|striptags('<p>')|raw }}
  {% endif %}
{% endset %}


{{ include('dripyard_base:card', {
  title: label,
  image: content.field_image|add_suggestion('bare'),
  eyebrow_text: date,
  body: body_text,
  href: url,
  }, with_context = false) }}
