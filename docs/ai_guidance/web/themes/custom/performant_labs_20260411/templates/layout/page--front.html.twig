{#
/**
 * @file
 * Full-width Canvas page template for the site front page (/page/1).
 *
 * Differences from the default page.html.twig:
 * - Page title block is suppressed — Canvas section headings carry all titles.
 * - The site-main wrapper has no container constraint; Canvas blocks fill the
 *   full viewport edge-to-edge.
 * - The body class `canvas-page` (added via performant_labs_20260411.theme)
 *   can be used to scope any CSS targeting this template.
 * - The header_third slot receives a hardcoded "Call today" CTA pill button
 *   if no block is placed in that region.
 *
 * @see template_preprocess_page()
 * @see neonbyte/templates/layout/page.html.twig
 */
#}
<div class="layout-container">

  {%- set header_cta -%}
    <a href="/contact" class="header-cta">Call today</a>
  {%- endset -%}

  {{ include('neonbyte:header', {
      header_first: page.header_first,
      header_second: page.header_second,
      header_third: page.header_third is not empty ? page.header_third : header_cta,
      attributes: header_attributes,
    }, with_context = false) }}

  {{ page.fixed_middle_right }}
  {{ page.fixed_bottom_right }}
  {{ page.highlighted }}

  {#
    site-main has no container class — Canvas blocks are full-width.
    The `canvas-page` body class allows targeted CSS without touching global layout.
  #}
  <main class="site-main canvas-page">
    <a id="main-content" tabindex="-1"></a>

    {{ include('@neonbyte/component-dev.html.twig', ignore_missing: true) }}

    {# page.content renders the Canvas field output — no page title block here #}
    {{ page.content }}
  </main>

  {% embed 'neonbyte:footer' with {
    footer_top: page.footer_top,
    footer_left: page.footer_left,
    footer_right: page.footer_right,
    footer_bottom: page.footer_bottom,
    theme: footer_theme,
  } only %}
    {% block footer_top_content %}
      {{- footer_top -}}
    {% endblock %}

    {% block footer_left_content %}
      {{- footer_left -}}
    {% endblock %}

    {% block footer_right_content %}
      <div class="footer-cta">
        <p class="heading h1" style="color:#fff;line-height:1.1;margin-bottom:1rem;">Be the answer.<br>Everywhere.</p>
        <a href="/contact" class="footer-cta__link">Get in touch →</a>
      </div>
      {{- footer_right -}}
    {% endblock %}

    {% block footer_bottom_content %}
      {{- footer_bottom -}}
      <div class="footer-social-icons" role="navigation" aria-label="Social media links">
        <a href="https://www.linkedin.com/company/performant-labs" class="footer-social-icons__link" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://github.com/Performant-Labs/" class="footer-social-icons__link" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </a>
        <a href="https://twitter.com/PerformantLabs" class="footer-social-icons__link" target="_blank" rel="noopener noreferrer" aria-label="Twitter / X">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.259 5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
      </div>
    {% endblock %}
  {% endembed %}
</div>
