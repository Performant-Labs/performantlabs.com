{#
/**
 * @file
 * Implementation to display a node as a content card.
 */
#}
{% set metadata =  node.changed.value|date('j F Y') %}

{% set body_text %}
  {% if node.body.summary %}
    {{ node.body.summary }}
  {% else %}
    {{ content.body|add_suggestion('bare')|render|striptags('<p>')|raw }}
  {% endif %}
{% endset %}

{{ include('dripyard_base:content-card', {
  title: node.label,
  link_href: url,
  metadata: metadata,
  body_text: body_text,
  background: true,
}, with_context = false) }}
