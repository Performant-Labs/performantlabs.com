{#
/**
 * @file
 * Implementation to display a node as an accordion item.
 */
#}
{% embed 'dripyard_base:accordion-item' with {
  title: node.label,
  open: false,
  content,
} only %}
  {% block accordion_item_content %}
    {{ content.body }}
    {{ content|without('body', 'links') }}
  {% endblock %}
{% endembed %}
