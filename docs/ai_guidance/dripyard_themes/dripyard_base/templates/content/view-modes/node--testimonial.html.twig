{#
/**
 * @file
 * Implementation to display a node as a testimonial.
 */
#}
{% set image = content.field_featured_image ?: content.field_image %}

{% set body_text %}
  {% if node.body.summary %}
    {{ node.body.summary }}
  {% else %}
    {{ content.body|add_suggestion('bare')|render|striptags('<p>')|raw }}
  {% endif %}
{% endset %}

{{ include('dripyard_base:testimonial', {
  quote: body_text,
  citation: author_name,
  image: image|add_suggestion('bare'),
  reversed: false,
}, with_context = false) }}
