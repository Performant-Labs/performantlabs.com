{#
/**
 * @file
 * Implementation to display a node as an icon card.
 */
#}

{% set body_text %}
  {% if node.body.summary %}
    {{ node.body.summary }}
  {% else %}
    {{ content.body|add_suggestion('bare')|render|striptags('<p>')|raw }}
  {% endif %}
{% endset %}

{{ include('dripyard_base:icon-card', {
  icon: 'drupal',
  title: node.label,
  body: body_text,
  href: url,
  layout: 'portrait',
  icon_size: 'medium',
  no_background: false,
}, with_context = false) }}
