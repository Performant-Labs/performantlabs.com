{#
/**
 * @file
 * Implementation to display a node as a card with full image background.
 */
#}
{% set image = content.field_featured_image ?: content.field_image %}

{{ include('dripyard_base:card-full-image', {
  image: image|add_suggestion('bare'),
  title: node.label,
  byline: 'Learn more'|t,
  href: url,
  overlay_color: 'dark',
  overlay: 'full',
  layout_vertical: 'bottom',
  title_align: 'start',
  byline_align: 'start',
}, with_context = false) }}
